server {
    server_name localhost;

    location = /favicon.ico { access_log off; log_not_found off; }
    location /static/ {
        root /app/clarityv2;
    }

    location / {
        proxy_pass http://unix:/app/clarityv2/clarityv2.sock;
    }

    location /media  {
        alias /app/clarityv2/media;
    }

    location /protected {
        internal;
        access_log /var/log/nginx/private.prod.access.log;
        alias /app/clarityv2/private_media;
    }
}
